# PostgreSQL
POSTGRES_DB=sharepwd
POSTGRES_USER=sharepwd
POSTGRES_PASSWORD=changeme

# MinIO / S3
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=changeme
S3_BUCKET=sharepwd

# Backend
BASE_URL=https://sharepwd.io
CORS_ORIGINS=https://sharepwd.io
GRACE_PERIOD_MINUTES=2
MAX_TEXT_SIZE=102400
MAX_FILE_SIZE=104857600
CLEANUP_INTERVAL=60s

# Frontend
NEXT_PUBLIC_API_URL=https://sharepwd.io
NEXT_PUBLIC_APP_URL=https://sharepwd.io

# Anti-bot defense layers
CHALLENGE_MIN_SOLVE_TIME=1500ms
CHALLENGE_TTL=5m
POW_DIFFICULTY=20
BEHAVIORAL_MIN_SCORE=30
ENV_MIN_SCORE=20
MAX_NONCES_PER_IP=3
METADATA_RATE_LIMIT=10
DEFENSE_STRICT_MODE=false

# Umami Analytics
UMAMI_DB_PASSWORD=changeme
UMAMI_APP_SECRET=changeme
# Set after creating a site in Umami dashboard
# NEXT_PUBLIC_UMAMI_WEBSITE_ID=
